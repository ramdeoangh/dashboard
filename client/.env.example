# Copy to `.env`, `.env.local`, or mode-specific files (`.env.development`, `.env.production`).
# Only variables prefixed with VITE_ are exposed to the app.

# API base URL (must include the `/api` path if your server mounts routes there).
# Dev with Vite proxy: relative path so requests stay on the dev host.
# Leave unset, blank, or omit — defaults to /api (see client/src/config.js).
VITE_API_BASE_URL=/api

# Public URL prefix for static uploads (logo, etc.).
# Blank or unset defaults to /uploads.
VITE_UPLOADS_BASE_URL=/uploads

# Dev server only: backend origin for `/api` and `/uploads` proxy (see vite.config.js).
VITE_DEV_PROXY_TARGET=http://localhost:4000

# Production example (API on another host):
# VITE_API_BASE_URL=https://api.example.com/api
# VITE_UPLOADS_BASE_URL=https://api.example.com/uploads
