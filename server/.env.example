NODE_ENV=development
PORT=4000
# Must match the Vite dev server origin (see client/vite.config.js proxy).
CLIENT_ORIGIN=http://localhost:5173

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_password
DATABASE_NAME=project_dashboard

JWT_ACCESS_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_also_long_random
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5

# application_logs: errors only by default (structured JSON in meta). Set LOG_HTTP_TO_DB=true to also log each /api request.
LOG_HTTP_TO_DB=false
LOG_ERRORS_TO_DB=true

# One-off: npm run db:reset-admin — set then remove after use
# ADMIN_PASSWORD=YourNewPassword

# Re-seed: set SEED_ADMIN_PASSWORD then SEED_UPDATE_ADMIN_PASSWORD=1 npm run db:seed
