NODE_ENV=development
PORT=4000
# Browser origins allowed by CORS (comma-separated). Trailing slashes are OK.
# Example production + local dev:
# CLIENT_ORIGIN=https://dashboard.y4dinfo.org,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# Optional: public API origin (no trailing slash). Used for Swagger "Servers" and absolute /uploads URLs in JSON
# (so dashboards on another domain get https://api…/uploads/… instead of root-relative /uploads/…).
# PUBLIC_API_URL=https://api.y4d.ngo

# Production: set a long random secret, then open once: /api/docs/?docs_token=<same value> (sets cookie; also X-API-Docs-Token or Bearer work)
# SWAGGER_DOCS_TOKEN=

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_password
DATABASE_NAME=project_dashboard

JWT_ACCESS_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_also_long_random
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

# --- Optional (only if you need overrides) ---
# Refresh cookie SameSite: if unset, defaults use `none` in production / when UI host ≠ API host.
# Same host for UI + API only: REFRESH_COOKIE_SAMESITE=lax
# REFRESH_COOKIE_SAMESITE=strict

# Split dashboard + API on different domains: you do NOT have to set anything below if PUBLIC_API_URL is set
# (e.g. https://api.example.com) or if NODE_ENV=production with PUBLIC_API_URL omitted (body refresh is auto-on).
# Force refresh token in login JSON + sessionStorage flow even when auto rules are off:
# ALLOW_REFRESH_TOKEN_BODY=true
# Turn off body refresh if you only use same-site httpOnly cookies:
# DISALLOW_REFRESH_TOKEN_BODY=true

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5

# application_logs: errors only by default (structured JSON in meta). Set LOG_HTTP_TO_DB=true to also log each /api request.
LOG_HTTP_TO_DB=false
LOG_ERRORS_TO_DB=true

# One-off: npm run db:reset-admin — set then remove after use
# ADMIN_PASSWORD=YourNewPassword

# Re-seed: set SEED_ADMIN_PASSWORD then SEED_UPDATE_ADMIN_PASSWORD=1 npm run db:seed
